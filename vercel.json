{
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "backend/server.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": "backend/*.csv"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "backend/server.py"
    }
  ]
}